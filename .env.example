# HMHS Era Environment Configuration Template
# Copy this file to .env and configure for your environment

# ============================================
# Model Configuration
# ============================================
# Path to GGUF model files (leave empty to use default ./models)
HMHS_MODEL_PATH=./models

# Enable GPU acceleration (true/false)
HMHS_GPU=false

# Maximum tokens for inference
HMHS_MAX_TOKENS=512

# Temperature for model sampling (0.0 to 2.0)
HMHS_TEMPERATURE=0.7

# ============================================
# Database Configuration
# ============================================
# Vector database storage path
HMHS_VECTOR_DB_PATH=./db_data

# ============================================
# Logging Configuration
# ============================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# Performance Monitoring & DLL Acceleration
# ============================================
# Enable FPS monitoring (true/false)
HMHS_FPS_MONITOR=true

# FPS check interval in milliseconds
HMHS_FPS_INTERVAL=1000

# Enable HMHSFPS.dll hardware acceleration (true/false)
HMHS_DLL_ACCELERATION=true

# Hardware acceleration level (0-10, where 10 is maximum)
# 0 = no acceleration, 10 = maximum optimization
HMHS_ACCELERATION_LEVEL=8

# Path to HMHSFPS.dll file
HMHS_DLL_PATH=./HMHSFPS.dll

# ============================================
# Framework Settings
# ============================================
# Enable verbose output (true/false)
HMHS_VERBOSE=false

# Air-gapped mode (should always be true for HMHS Era)
HMHS_AIR_GAPPED=true
